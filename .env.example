# ─── Sentry Error Tracking ──────────────────────────────────────────
# Get your DSN from https://sentry.io
# Create two projects: "praxis-backend" and "praxis-frontend"

# Backend DSN (Node.js)
SENTRY_DSN=https://your-dsn-key@o0.ingest.sentry.io/0

# Frontend DSN (React)
SENTRY_DSN_REACT=https://your-dsn-key@o0.ingest.sentry.io/0

# ─── Environment ────────────────────────────────────────────────────
NODE_ENV=production

# Public site URL — used for Stripe success/cancel redirects, email links.
# Use the actual https URL in production, http://localhost:3000 in dev.
CLIENT_URL=https://praxisweb.xyz

# ─── Supabase ───────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role_jwt   # Settings → API → service_role
DATABASE_URL=postgresql://...                       # Settings → Database → Connection string

# ─── Stripe ─────────────────────────────────────────────────────────
# Test keys (sk_test_*, price_test_*) for staging, live keys for production.
# Backend at startup verifies that production uses sk_live_*.

STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_ID=price_...                     # Monthly subscription price
STRIPE_PRICE_ID_ANNUAL=price_...              # Annual subscription price
STRIPE_WEBHOOK_SECRET=whsec_...               # Endpoint signing secret (per-environment)

# Frontend (must be prefixed REACT_APP_* to be exposed to the React build)
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Production webhook endpoint:
#   https://web-production-646a4.up.railway.app/api/stripe/webhook
# Subscribed events (configure in Stripe Dashboard → Developers → Webhooks):
#   checkout.session.completed
#   customer.subscription.updated
#   customer.subscription.deleted
#
# Local end-to-end testing:
#   stripe login
#   stripe listen --forward-to localhost:3001/api/stripe/webhook
#   # Copy the printed whsec_* into STRIPE_WEBHOOK_SECRET, restart backend
#   stripe trigger checkout.session.completed
#
# See `scripts/stripe-cli-test.sh` and the Stripe section of
# manual_actions.txt for the full production checklist.
