# ─────────────────────────────────────────────────────────────
# Configurazione principale di Oh My Zsh
# ─────────────────────────────────────────────────────────────
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="powerlevel10k/powerlevel10k" # Tema visuale avanzato
plugins=(git) # Plugin per integrazione con Git

# ─────────────────────────────────────────────────────────────
# Plugin esterni (suggerimenti e colorazione sintassi)
# ─────────────────────────────────────────────────────────────
source /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# ─────────────────────────────────────────────────────────────
# PATH: Percorsi di ricerca dei programmi
# ─────────────────────────────────────────────────────────────
export ANDROID_HOME="$HOME/Android/Sdk"

typeset -U path # Evita duplicati nel PATH
path=(
    "$ANDROID_HOME/emulator"
    "$ANDROID_HOME/platform-tools"
    "$ANDROID_HOME/tools/bin"
    /opt/zig/0.16.0
    /usr/sbin
    ~/scripts
    "$HOME/.npm-global/bin"
    "$HOME/.local/bin"           # pipx e strumenti python
    $path
)

# ─────────────────────────────────────────────────────────────
# Gestione Cronologia e Comportamento Shell
# ─────────────────────────────────────────────────────────────
HISTSIZE=10000
SAVEHIST=20000
setopt APPEND_HISTORY      # Aggiunge alla cronologia invece di sovrascrivere
setopt SHARE_HISTORY       # Condivide la cronologia tra diverse finestre
setopt HIST_IGNORE_ALL_DUPS # Non salvare comandi duplicati
setopt HIST_REDUCE_BLANKS  # Rimuove spazi superflui
setopt INC_APPEND_HISTORY  # Salva i comandi appena eseguiti
setopt CORRECT             # Suggerisce correzioni per comandi errati
setopt CORRECT_ALL         # Correzione estesa a tutto il comando

# ─────────────────────────────────────────────────────────────
# Caricamento Oh My Zsh
# ─────────────────────────────────────────────────────────────
source $ZSH/oh-my-zsh.sh

# ─────────────────────────────────────────────────────────────
# Integrazione Strumenti Esterni
# ─────────────────────────────────────────────────────────────
