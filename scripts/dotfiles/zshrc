# ============================================
# Utilità LaTeX
# ============================================

# Conta le parole nel documento LaTeX
texwords() {
    if [ -z "$1" ]; then
        echo "Uso: texwords <file.tex>"
        return 1
    fi
    detex "$1" | wc -w
}

# Trova citazioni o riferimenti mancanti
texmissing() {
    if [ -z "$1" ]; then
        grep -n "??" *.log 2>/dev/null || echo "Nessun riferimento mancante trovato"
    else
        grep -n "??" "$1.log" 2>/dev/null || echo "Nessun riferimento mancante trovato"
    fi
}

# Trova riferimenti non definiti
texundef() {
    if [ -z "$1" ]; then
        grep -n "undefined" *.log 2>/dev/null || echo "Nessun riferimento non definito"
    else
        grep -n "undefined" "$1.log" 2>/dev/null || echo "Nessun riferimento non definito"
    fi
}

# ============================================
# Processamento Batch
# ============================================

# Compila tutti i file .tex nella cartella
texall() {
    for file in *.tex; do
        echo "Compilazione di $file..."
        base=$(basename "$file" .tex)
        latexmk -xelatex -bibtex -interaction=nonstopmode "$base"
    done
}

texrebuild-all() {
    texclean
    texall
}

# Visualizzatore PDF intelligente per diversi sistemi
pdfopen() {
    if [ -z "$1" ]; then
        echo "Uso: pdfopen <file.pdf>"
        return 1
    fi
    
    case "$(uname -s)" in
        Darwin)
            open "$1"
            ;;
        Linux)
            if command -v xdg-open >/dev/null 2>&1; then
                xdg-open "$1"
            elif command -v evince >/dev/null 2>&1; then
                evince "$1" &
            elif command -v okular >/dev/null 2>&1; then
                okular "$1" &
            else
                echo "Nessun visualizzatore PDF trovato"
            fi
            ;;
        CYGWIN*|MINGW32*|MSYS*|MINGW*)
            start "$1"
            ;;
        *)
            echo "Sistema operativo sconosciuto"
            ;;
    esac
}

