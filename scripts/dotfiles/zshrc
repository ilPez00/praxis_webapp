# ─────────────────────────────────────────────────────────────
# Sezione LaTex: Automazione compilazione documenti
# ─────────────────────────────────────────────────────────────
# ============================================
# Alias per Compilazione LaTeX
# ============================================

# Compilazione base
alias latexmk='latexmk -xelatex'  # Usa xelatex come predefinito
alias xelatex='xelatex'
alias pdflatex='pdflatex'

# Compilazione rapida (singolo passaggio)
alias qtex='xelatex *.tex'

# Compilazione completa con bibliografia
alias texit='latexmk -xelatex -bibtex -interaction=nonstopmode *.tex'
alias texfull='latexmk -xelatex -bibtex -interaction=nonstopmode -f *.tex'

# Funzioni per documenti specifici
texdoc() {
    if [ -z "$1" ]; then
        echo "Uso: texdoc <nome_file senza .tex>"
        return 1
    fi
    latexmk -xelatex -bibtex -interaction=nonstopmode "$1.tex"
}

# Visualizzazione rapida (compila e apre)
texview() {
    if [ -z "$1" ]; then
        echo "Uso: texview <nome_file senza .tex>"
        return 1
    fi
    latexmk -xelatex -pvc -interaction=nonstopmode "$1.tex"
}

# ============================================
# Gestione Bibliografia
# ============================================

alias bib='bibtex *.aux'
alias bibtex-all='for f in *.aux; do bibtex $f; done'

# Ciclo completo di bibliografia
alias biblatex='xelatex *.tex && bibtex *.aux && xelatex *.tex && xelatex *.tex'

bibdoc() {
    if [ -z "$1" ]; then
        echo "Uso: bibdoc <nome_file senza .tex>"
        return 1
    fi
    xelatex "$1.tex"
    bibtex "$1.aux"
    xelatex "$1.tex"
    xelatex "$1.tex"
}

# ============================================
# Pulizia File Temporanei LaTeX
# ============================================

alias texclean='rm -f *.aux *.log *.out *.toc *.bbl *.blg *.lof *.lot *.fls *.fdb_latexmk *.synctex.gz *.nav *.snm *.vrb *.run.xml *.bcf *.xdv'
alias texclean-hard='rm -f *.aux *.log *.out *.toc *.bbl *.blg *.lof *.lot *.fls *.fdb_latexmk *.synctex.gz *.nav *.snm *.vrb *.run.xml *.bcf *.xdv *.dvi *.ps'

texclean-project() {
    if [ -z "$1" ]; then
        echo "Uso: texclean-project <nome_file senza .tex>"
        return 1
    fi
    rm -f "$1.aux" "$1.log" "$1.out" "$1.toc" "$1.bbl" "$1.blg" "$1.lof" "$1.lot" "$1.fls" "$1.fdb_latexmk" "$1.synctex.gz" "$1.nav" "$1.snm" "$1.vrb" "$1.run.xml" "$1.bcf"
}

alias texclean-all='find . -name "*.aux" -o -name "*.log" -o -name "*.out" -o -name "*.toc" -o -name "*.bbl" -o -name "*.blg" -o -name "*.lof" -o -name "*.lot" -o -name "*.fls" -o -name "*.fdb_latexmk" -o -name "*.synctex.gz" -o -name "*.nav" -o -name "*.snm" -o -name "*.vrb" -o -name "*.run.xml" -o -name "*.bcf" | xargs rm -f'

# ============================================
# Workflow Completi
# ============================================

# Compila, gestisce bibliografia, pulisce e apre il PDF
texwork() {
    if [ -z "$1" ]; then
        echo "Uso: texwork <nome_file senza .tex>"
        return 1
    fi
    
    echo "📄 Compilazione in corso di $1.tex..."
    xelatex "$1.tex"
    
    echo "📚 Generazione bibliografia..."
    if [ -f "$1.aux" ]; then
        bibtex "$1.aux"
    fi
    
    echo "🔄 Compilazioni finali..."
    xelatex "$1.tex"
    xelatex "$1.tex"
    
    echo "🧹 Pulizia file temporanei..."
    texclean-project "$1"
    
    echo "✅ Fatto! Apertura $1.pdf..."
    open "$1.pdf" 2>/dev/null || xdg-open "$1.pdf" 2>/dev/null || start "$1.pdf" 2>/dev/null
}

texmake() {
    if [ -z "$1" ]; then
        echo "Uso: texmake <nome_file senza .tex>"
        return 1
    fi
    
    latexmk -xelatex -interaction=nonstopmode "$1.tex"
    if [ -f "$1.pdf" ]; then
        open "$1.pdf" 2>/dev/null || xdg-open "$1.pdf" 2>/dev/null || start "$1.pdf" 2>/dev/null
    fi
}

