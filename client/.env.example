# ─── Supabase (Frontend — anon key, safe to expose to browser) ───────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your_anon_key

# ─── Stripe (Frontend — publishable key only, safe to expose) ────────────────
# NOTE: Currently unused — all Stripe flow is server-side (hosted checkout).
# Reserved for future Elements integration.
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...your_publishable_key

# ─── Backend API ─────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001/api

# ─── Sentry (Frontend) ─────────────────────────────────────────────────────────
VITE_SENTRY_DSN_REACT=https://your-dsn-key@o0.ingest.sentry.io/0
